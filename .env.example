# .env.example — Sao chép thành .env và điền thông tin thực tế
# KHONG commit file .env lên git!

# Flask
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-64

# SMTP - dung de gui email phishing thuc te (chi trong mang noi bo!)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Domain noi bo cho phishing landing pages
PHISHING_DOMAIN=localhost

# Subnet noi bo (dong bo voi docker-compose.yml)
INTERNAL_NETWORK=10.0.10.0/24
